# RON3IA Backend Environment Variables - EXAMPLE
# Copia este archivo como .env y completa los valores

# Security (GENERAR CON: .\New-SecureEnvFile.ps1)
RON3IA_SECRET_TOKEN=<GENERAR_TOKEN_SEGURO>
JWT_SECRET_KEY=<GENERAR_JWT_SECRET>
API_KEY=<GENERAR_API_KEY>

# Server
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development

# CORS
ALLOWED_ORIGINS=https://ron3ia.cl,https://ronrodrigo3.com,http://localhost:3000

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/ron3ia.log

# Paths
COMPOSE_BASE_DIR=./configs
PS_EXECUTOR=./scripts/yaml-commit-executor.ps1
SANDBOX_ROOT=C:\RON3IA_Sandbox\repo_test
